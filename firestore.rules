rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
              (request.auth.token.email == "actoftod@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= minLen && 
              request.resource.data[field].size() <= maxLen);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUserProfile() {
      let data = request.resource.data;
      return (!('email' in data) || (data.email is string && data.email.size() < 100)) &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidArtwork() {
      let data = request.resource.data;
      return data.userId == request.auth.uid &&
             data.imageUrl is string && data.imageUrl.size() < 1048576 && // 1MB limit for base64
             (!('name' in data) || (data.name is string && data.name.size() < 200));
    }

    function isValidLibrary() {
      let data = request.resource.data;
      return (!('styleImages' in data) || data.styleImages is list) &&
             (!('styleDNA' in data) || (data.styleDNA is string && data.styleDNA.size() < 5000));
    }

    function isValidUserMemory() {
      let data = request.resource.data;
      return (!('preferredAspectRatios' in data) || data.preferredAspectRatios is list) &&
             (!('frequentKeywords' in data) || data.frequentKeywords is list) &&
             (!('interactionsCount' in data) || data.interactionsCount is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserProfile() && uidUnchanged() && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUserProfile() && uidNotModified() && 
                    ((!('role' in request.resource.data) || request.resource.data.role == resource.data.role) || isAdmin());
      
      match /artworks/{artworkId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidArtwork();
        allow update: if isOwner(userId) && isValidArtwork();
        allow delete: if isOwner(userId) || isAdmin();
      }

      match /generations/{generationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /templates/{templateId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /projects/{projectId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }

      match /memory/{memoryId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /libraries/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidLibrary();
      allow update: if isOwner(userId) && isValidLibrary();
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /style_battles/{battleId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /tribes/{tribeId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /marketplace_listings/{listingId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
